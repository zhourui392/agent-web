{
  "name": "agent-web-tests",
  "version": "0.1.0",
  "private": true,
  "description": "E2E and frontend unit tests for agent-web (independent npm workspace, not part of Maven build).",
  "scripts": {
    "e2e": "playwright test",
    "e2e:clean": "node ./scripts/e2e-clean.js",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "test:install": "playwright install --with-deps chromium",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "vitest": "^3.0.0"
  }
}
